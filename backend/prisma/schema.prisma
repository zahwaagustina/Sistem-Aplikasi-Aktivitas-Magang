generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  MENTOR
  UNIT
  KANDIDAT
  MAGANG
  MANAJEMEN
  KAMPUS
}

enum StatusPendaftaran {
  DRAFT
  SUBMITTED
  REVIEWED
  SHORTLISTED
  WAITING_KESANGGUPAN
  KESANGGUPAN_FILLED
  INTERVIEW
  ACCEPTED
  REJECTED
}

enum StatusLowongan {
  DRAFT
  OPEN
  CLOSED
}

enum ModeKerja {
  WFO
  WFH
  HYBRID
}

enum StatusMagang {
  AKTIF
  CUTI
  SELESAI
  RESIGN
  DIBERHENTIKAN
}

enum StatusAktivitas {
  DRAFT
  TERKIRIM
  DISETUJUI
  REVISI
  TELAT_MENGISI
}

enum StatusOnboarding {
  WAITING_CONFIRMATION
  REJECTED_BY_CANDIDATE
  DOCUMENT_VERIFICATION
  DOCUMENT_REVISION
  LOA_ISSUED
  PLACEMENT_ASSIGNED
  ACCOUNT_CREATED
  CHECKLIST_IN_PROGRESS
  ORIENTATION_SCHEDULED
  COMPLETED
}

enum StatusAbsensi {
  HADIR
  IZIN
  SAKIT
  ALPA
}

enum PrioritasTugas {
  LOW
  MEDIUM
  HIGH
}

enum StatusTugas {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TipeEvaluasi {
  MID_TERM
  FINAL
}

model User {
  id         Int      @id @default(autoincrement())
  username   String   @unique
  password   String
  email                String?   @unique
  is_verified          Boolean   @default(true)
  verification_token   String?   @unique
  verification_expires DateTime?
  nama                 String
  role                 Role
  no_telepon           String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relasi berdasarkan peran
  profilKandidat    ProfilKandidat?
  profilMagang      ProfilMagang?
  pendaftaran       Pendaftaran[]
  aktivitas         AktivitasHarian[]
  absensi           Absensi[]
  tugasDiberikan    Tugas[]           @relation("TugasMentor")
  tugasDiterima     Tugas[]           @relation("TugasPeserta")
  evaluasiDiberikan HasilEvaluasi[]   @relation("EvaluasiMentor")
  evaluasiDiterima  HasilEvaluasi[]   @relation("EvaluasiPeserta")
  dokumen           Dokumen[]
  auditTrails       AuditTrail[]
  onboardingDimementori Onboarding[]  @relation("OnboardingMentor")
  notifikasi        Notifikasi[]
  passwordResetTokens PasswordResetToken[]
  masterTemplates   MasterTemplate[]
  dynamicFormResponses DynamicFormResponse[]
}

model ProfilKandidat {
  id             Int     @id @default(autoincrement())
  user_id        Int     @unique
  user           User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  npm            String?
  universitas    String?
  jurusan        String?
  angkatan       String?
  semester       String?
  cv_path        String?
  portofolio_url String?
}

model ProfilMagang {
  id              Int          @id @default(autoincrement())
  user_id         Int          @unique
  user            User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  id_magang       String?      @unique
  universitas     String?
  jurusan         String?
  angkatan        String?
  semester        String?
  mentor_id       Int?
  divisi          String?
  lokasi          String?
  tanggal_mulai   DateTime?    @db.Date
  tanggal_selesai DateTime?    @db.Date
  status          StatusMagang @default(AKTIF)
}

model ProgramBatch {
  id              Int        @id @default(autoincrement())
  nama            String
  tanggal_mulai   DateTime   @db.Date
  tanggal_selesai DateTime   @db.Date
  is_active       Boolean    @default(true)
  lowongan        Lowongan[]
}

model Lowongan {
  id          Int            @id @default(autoincrement())
  program_id  Int
  program     ProgramBatch   @relation(fields: [program_id], references: [id])
  posisi      String
  deskripsi   String         @db.Text
  kualifikasi String         @db.Text
  benefit     String?        @db.Text
  divisi      String
  lokasi      String
  mode_kerja  ModeKerja      @default(WFO)
  kuota       Int
  status      StatusLowongan @default(OPEN)
  created_at  DateTime       @default(now())
  pendaftaran Pendaftaran[]
}

model Pendaftaran {
  id              Int               @id @default(autoincrement())
  user_id         Int
  user            User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  lowongan_id     Int
  lowongan        Lowongan          @relation(fields: [lowongan_id], references: [id])
  status          StatusPendaftaran @default(SUBMITTED)
  surat_pengantar String?
  catatan_hr      String?           @db.Text
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt
  interview       Interview?
  onboarding      Onboarding?
  dynamicFormResponses DynamicFormResponse[]
}

model Interview {
  id             Int         @id @default(autoincrement())
  pendaftaran_id Int         @unique
  pendaftaran    Pendaftaran @relation(fields: [pendaftaran_id], references: [id], onDelete: Cascade)
  tanggal_waktu  DateTime
  link_meeting   String?
  hasil_score    Float?
  skor_wawancara Float?
  skor_psikotes  Float?
  skor_teknikal  Float?
  catatan        String?     @db.Text
}

model AktivitasHarian {
  id                 Int             @id @default(autoincrement())
  user_id            Int
  user               User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tanggal            DateTime        @db.Date
  deskripsi_kegiatan String          @db.Text
  hasil_kegiatan     String          @db.Text
  waktu_mulai        String          @db.VarChar(5)
  waktu_selesai      String          @db.VarChar(5)
  kendala            String?         @db.Text
  status             StatusAktivitas @default(DRAFT)
  komentar_mentor    String?         @db.Text
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt
  lampiran           Lampiran[]

  @@map("aktivitas_harian")
}

model Lampiran {
  id           Int             @id @default(autoincrement())
  aktivitas_id Int
  aktivitas    AktivitasHarian @relation(fields: [aktivitas_id], references: [id], onDelete: Cascade)
  nama_file    String
  file_path    String
  created_at   DateTime        @default(now())

  @@map("lampiran")
}

model Absensi {
  id            Int           @id @default(autoincrement())
  user_id       Int
  user          User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tanggal       DateTime      @db.Date
  waktu_masuk   DateTime?
  waktu_keluar  DateTime?
  lokasi_masuk  String?
  lokasi_keluar String?
  status        StatusAbsensi @default(HADIR)
  keterangan    String?       @db.Text
  bukti_path    String?
  created_at    DateTime      @default(now())
}

model Tugas {
  id         Int            @id @default(autoincrement())
  mentor_id  Int
  mentor     User           @relation("TugasMentor", fields: [mentor_id], references: [id], onDelete: Cascade)
  peserta_id Int
  peserta    User           @relation("TugasPeserta", fields: [peserta_id], references: [id], onDelete: Cascade)
  judul      String
  deskripsi  String         @db.Text
  deadline   DateTime       @db.Date
  prioritas  PrioritasTugas @default(MEDIUM)
  status     StatusTugas    @default(TODO)
  file_hasil String?
  feedback   String?        @db.Text
  file_feedback String?
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt
}

model AspekPenilaian {
  id         Int      @id @default(autoincrement())
  nama       String
  bobot      Float
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  
  pertanyaan PertanyaanPenilaian[]
  
  @@map("tabel_aspek_penilaian")
}

model PertanyaanPenilaian {
  id          Int      @id @default(autoincrement())
  aspek_id    Int
  aspek       AspekPenilaian @relation(fields: [aspek_id], references: [id], onDelete: Cascade)
  pertanyaan  String   @db.Text
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  
  detailEvaluasi DetailEvaluasi[]
  
  @@map("tabel_pertanyaan_penilaian")
}

model HasilEvaluasi {
  id              Int          @id @default(autoincrement())
  peserta_id      Int
  peserta         User         @relation("EvaluasiPeserta", fields: [peserta_id], references: [id], onDelete: Cascade)
  mentor_id       Int
  mentor          User         @relation("EvaluasiMentor", fields: [mentor_id], references: [id], onDelete: Cascade)
  tipe            TipeEvaluasi
  skor_akhir      Float        @default(0)
  feedback        String       @db.Text
  created_at      DateTime     @default(now())

  detailEvaluasi  DetailEvaluasi[]
  
  @@map("tabel_hasil_evaluasi")
}

model DetailEvaluasi {
  id                Int                 @id @default(autoincrement())
  hasil_evaluasi_id Int
  hasilEvaluasi     HasilEvaluasi       @relation(fields: [hasil_evaluasi_id], references: [id], onDelete: Cascade)
  pertanyaan_id     Int
  pertanyaan        PertanyaanPenilaian @relation(fields: [pertanyaan_id], references: [id], onDelete: Cascade)
  skor              Int                 // 1-5
  
  @@map("tabel_detail_evaluasi")
}

model Dokumen {
  id         Int      @id @default(autoincrement())
  user_id    Int
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tipe       String // LOA, NDA, SERTIFIKAT, SURAT_KETERANGAN
  nama_file  String
  file_path  String
  created_at DateTime @default(now())
}

model AuditTrail {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  user       User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)
  aksi       String
  entitas    String
  entitas_id Int?
  detail     String?  @db.Text
  created_at DateTime @default(now())
}

model Onboarding {
  id              Int               @id @default(autoincrement())
  pendaftaran_id  Int               @unique
  pendaftaran     Pendaftaran       @relation(fields: [pendaftaran_id], references: [id], onDelete: Cascade)
  status          StatusOnboarding  @default(WAITING_CONFIRMATION)
  catatan_revisi  String?           @db.Text
  dokumen_revisi  Json?             
  is_loa_downloaded Boolean         @default(false)
  
  // Placement
  divisi          String?
  mentor_id       Int?
  mentor          User?             @relation("OnboardingMentor", fields: [mentor_id], references: [id])
  
  // Orientation
  jadwal_orientasi DateTime?
  link_orientasi   String?
  lokasi_orientasi String?
  konfirmasi_hadir Boolean          @default(false)

  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt

  checklist       OnboardingChecklist[]
}

model OnboardingChecklist {
  id              Int               @id @default(autoincrement())
  onboarding_id   Int
  onboarding      Onboarding        @relation(fields: [onboarding_id], references: [id], onDelete: Cascade)
  tugas           String
  is_completed    Boolean           @default(false)
  created_at      DateTime          @default(now())
}

model Notifikasi {
  id         Int      @id @default(autoincrement())
  user_id    Int
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  judul      String
  pesan      String   @db.Text
  is_read    Boolean  @default(false)
  link       String?
  created_at DateTime @default(now())
  expires_at DateTime? @default(dbgenerated("NOW() + INTERVAL '30 days'"))
  
  @@index([expires_at])
  @@map("notifikasi")
}

model PasswordResetToken {
  id         Int      @id @default(autoincrement())
  user_id    Int
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  email      String
  token      String   @unique
  expired_at DateTime
  created_at DateTime @default(now())

  @@map("password_reset_tokens")
}

model MasterTemplate {
  id            Int      @id @default(autoincrement())
  nama_template String
  deskripsi     String?  @db.Text
  nama_file     String
  path_file     String
  ekstensi      String
  ukuran_file   Int
  status        Boolean  @default(true)
  created_by    Int?
  user          User?    @relation(fields: [created_by], references: [id], onDelete: SetNull)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("master_templates")
}

enum TipeDynamicForm {
  KESANGGUPAN
  EVALUASI
}

enum TipePertanyaan {
  SHORT_TEXT
  PARAGRAPH
  RADIO
  CHECKBOX
  DROPDOWN
  DATE
}

model DynamicForm {
  id          Int      @id @default(autoincrement())
  judul       String
  deskripsi   String?  @db.Text
  tipe        TipeDynamicForm @default(KESANGGUPAN)
  is_active   Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  pertanyaan  DynamicFormQuestion[]
  respons     DynamicFormResponse[]

  @@map("dynamic_forms")
}

model DynamicFormQuestion {
  id              Int      @id @default(autoincrement())
  form_id         Int
  form            DynamicForm @relation(fields: [form_id], references: [id], onDelete: Cascade)
  pertanyaan      String   @db.Text
  tipe_pertanyaan TipePertanyaan
  is_required     Boolean  @default(true)
  opsi_json       Json?    
  urutan          Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  jawaban         DynamicFormAnswer[]

  @@map("dynamic_form_questions")
}

model DynamicFormResponse {
  id             Int         @id @default(autoincrement())
  form_id        Int
  form           DynamicForm @relation(fields: [form_id], references: [id], onDelete: Cascade)
  user_id        Int
  user           User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  pendaftaran_id Int
  pendaftaran    Pendaftaran @relation(fields: [pendaftaran_id], references: [id], onDelete: Cascade)
  status         String      @default("SUBMITTED")
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  jawaban        DynamicFormAnswer[]

  @@map("dynamic_form_responses")
}

model DynamicFormAnswer {
  id              Int                 @id @default(autoincrement())
  response_id     Int
  response        DynamicFormResponse @relation(fields: [response_id], references: [id], onDelete: Cascade)
  question_id     Int
  question        DynamicFormQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)
  jawaban_teks    String?             @db.Text
  jawaban_array   Json?               
  created_at      DateTime            @default(now())

  @@map("dynamic_form_answers")
}
