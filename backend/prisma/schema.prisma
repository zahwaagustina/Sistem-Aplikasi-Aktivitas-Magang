generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  HR_ADMIN
  MENTOR
  UNIT
  KANDIDAT
  MAGANG
  MANAJEMEN
  KAMPUS
}

enum StatusPendaftaran {
  DRAFT
  SUBMITTED
  REVIEWED
  SHORTLISTED
  INTERVIEW
  ACCEPTED
  REJECTED
}

enum StatusLowongan {
  DRAFT
  OPEN
  CLOSED
}

enum ModeKerja {
  WFO
  WFH
  HYBRID
}

enum StatusMagang {
  AKTIF
  CUTI
  SELESAI
  RESIGN
  DIBERHENTIKAN
}

enum StatusAktivitas {
  DRAFT
  TERKIRIM
  DISETUJUI
  REVISI
  TELAT_MENGISI
}

enum StatusOnboarding {
  WAITING_CONFIRMATION
  REJECTED_BY_CANDIDATE
  DOCUMENT_VERIFICATION
  DOCUMENT_REVISION
  LOA_ISSUED
  PLACEMENT_ASSIGNED
  ACCOUNT_CREATED
  CHECKLIST_IN_PROGRESS
  ORIENTATION_SCHEDULED
  COMPLETED
}

enum StatusAbsensi {
  HADIR
  IZIN
  SAKIT
  ALPA
}

enum PrioritasTugas {
  LOW
  MEDIUM
  HIGH
}

enum StatusTugas {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TipeEvaluasi {
  MID_TERM
  FINAL
}

model User {
  id         Int      @id @default(autoincrement())
  username   String   @unique
  password   String
  email                String?   @unique
  is_verified          Boolean   @default(true)
  verification_token   String?   @unique
  verification_expires DateTime?
  nama                 String
  role                 Role
  no_telepon           String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relasi berdasarkan peran
  profilKandidat    ProfilKandidat?
  profilMagang      ProfilMagang?
  pendaftaran       Pendaftaran[]
  aktivitas         AktivitasHarian[]
  absensi           Absensi[]
  tugasDiberikan    Tugas[]           @relation("TugasMentor")
  tugasDiterima     Tugas[]           @relation("TugasPeserta")
  evaluasiDiberikan Evaluasi[]        @relation("EvaluasiMentor")
  evaluasiDiterima  Evaluasi[]        @relation("EvaluasiPeserta")
  dokumen           Dokumen[]
  auditTrails       AuditTrail[]
  onboardingDimementori Onboarding[]  @relation("OnboardingMentor")
  notifikasi        Notifikasi[]
}

model ProfilKandidat {
  id             Int     @id @default(autoincrement())
  user_id        Int     @unique
  user           User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  universitas    String?
  jurusan        String?
  angkatan       String?
  semester       String?
  cv_path        String?
  portofolio_url String?
}

model ProfilMagang {
  id              Int          @id @default(autoincrement())
  user_id         Int          @unique
  user            User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  id_magang       String?      @unique
  universitas     String?
  jurusan         String?
  angkatan        String?
  semester        String?
  mentor_id       Int?
  divisi          String?
  lokasi          String?
  tanggal_mulai   DateTime?    @db.Date
  tanggal_selesai DateTime?    @db.Date
  status          StatusMagang @default(AKTIF)
}

model ProgramBatch {
  id              Int        @id @default(autoincrement())
  nama            String
  tanggal_mulai   DateTime   @db.Date
  tanggal_selesai DateTime   @db.Date
  is_active       Boolean    @default(true)
  lowongan        Lowongan[]
}

model Lowongan {
  id          Int            @id @default(autoincrement())
  program_id  Int
  program     ProgramBatch   @relation(fields: [program_id], references: [id])
  posisi      String
  deskripsi   String         @db.Text
  kualifikasi String         @db.Text
  benefit     String?        @db.Text
  divisi      String
  lokasi      String
  mode_kerja  ModeKerja      @default(WFO)
  kuota       Int
  status      StatusLowongan @default(OPEN)
  created_at  DateTime       @default(now())
  pendaftaran Pendaftaran[]
}

model Pendaftaran {
  id              Int               @id @default(autoincrement())
  user_id         Int
  user            User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  lowongan_id     Int
  lowongan        Lowongan          @relation(fields: [lowongan_id], references: [id])
  status          StatusPendaftaran @default(SUBMITTED)
  surat_pengantar String?
  catatan_hr      String?           @db.Text
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt
  interview       Interview?
  onboarding      Onboarding?
}

model Interview {
  id             Int         @id @default(autoincrement())
  pendaftaran_id Int         @unique
  pendaftaran    Pendaftaran @relation(fields: [pendaftaran_id], references: [id], onDelete: Cascade)
  tanggal_waktu  DateTime
  link_meeting   String?
  hasil_score    Float?
  catatan        String?     @db.Text
}

model AktivitasHarian {
  id                 Int             @id @default(autoincrement())
  user_id            Int
  user               User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tanggal            DateTime        @db.Date
  deskripsi_kegiatan String          @db.Text
  hasil_kegiatan     String          @db.Text
  waktu_mulai        String          @db.VarChar(5)
  waktu_selesai      String          @db.VarChar(5)
  kendala            String?         @db.Text
  status             StatusAktivitas @default(DRAFT)
  komentar_mentor    String?         @db.Text
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt
  lampiran           Lampiran[]

  @@map("aktivitas_harian")
}

model Lampiran {
  id           Int             @id @default(autoincrement())
  aktivitas_id Int
  aktivitas    AktivitasHarian @relation(fields: [aktivitas_id], references: [id], onDelete: Cascade)
  nama_file    String
  file_path    String
  created_at   DateTime        @default(now())

  @@map("lampiran")
}

model Absensi {
  id            Int           @id @default(autoincrement())
  user_id       Int
  user          User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tanggal       DateTime      @db.Date
  waktu_masuk   DateTime?
  waktu_keluar  DateTime?
  lokasi_masuk  String?
  lokasi_keluar String?
  status        StatusAbsensi @default(HADIR)
  keterangan    String?       @db.Text
  created_at    DateTime      @default(now())
}

model Tugas {
  id         Int            @id @default(autoincrement())
  mentor_id  Int
  mentor     User           @relation("TugasMentor", fields: [mentor_id], references: [id])
  peserta_id Int
  peserta    User           @relation("TugasPeserta", fields: [peserta_id], references: [id])
  judul      String
  deskripsi  String         @db.Text
  deadline   DateTime       @db.Date
  prioritas  PrioritasTugas @default(MEDIUM)
  status     StatusTugas    @default(TODO)
  file_hasil String?
  feedback   String?        @db.Text
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt
}

model Evaluasi {
  id              Int          @id @default(autoincrement())
  peserta_id      Int
  peserta         User         @relation("EvaluasiPeserta", fields: [peserta_id], references: [id])
  mentor_id       Int
  mentor          User         @relation("EvaluasiMentor", fields: [mentor_id], references: [id])
  tipe            TipeEvaluasi
  skor_teknis     Float
  skor_komunikasi Float
  skor_disiplin   Float
  skor_inisiatif  Float
  skor_teamwork   Float
  feedback        String       @db.Text
  created_at      DateTime     @default(now())
}

model Dokumen {
  id         Int      @id @default(autoincrement())
  user_id    Int
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tipe       String // LOA, NDA, SERTIFIKAT, SURAT_KETERANGAN
  nama_file  String
  file_path  String
  created_at DateTime @default(now())
}

model AuditTrail {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  user       User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)
  aksi       String
  entitas    String
  entitas_id Int?
  detail     String?  @db.Text
  created_at DateTime @default(now())
}

model Onboarding {
  id              Int               @id @default(autoincrement())
  pendaftaran_id  Int               @unique
  pendaftaran     Pendaftaran       @relation(fields: [pendaftaran_id], references: [id], onDelete: Cascade)
  status          StatusOnboarding  @default(WAITING_CONFIRMATION)
  
  // Placement
  divisi          String?
  mentor_id       Int?
  mentor          User?             @relation("OnboardingMentor", fields: [mentor_id], references: [id])
  
  // Orientation
  jadwal_orientasi DateTime?
  link_orientasi   String?
  lokasi_orientasi String?
  konfirmasi_hadir Boolean          @default(false)

  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt

  checklist       OnboardingChecklist[]
}

model OnboardingChecklist {
  id              Int               @id @default(autoincrement())
  onboarding_id   Int
  onboarding      Onboarding        @relation(fields: [onboarding_id], references: [id], onDelete: Cascade)
  tugas           String
  is_completed    Boolean           @default(false)
  created_at      DateTime          @default(now())
}

model Notifikasi {
  id         Int      @id @default(autoincrement())
  user_id    Int
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  judul      String
  pesan      String   @db.Text
  is_read    Boolean  @default(false)
  link       String?
  created_at DateTime @default(now())
  
  @@map("notifikasi")
}

