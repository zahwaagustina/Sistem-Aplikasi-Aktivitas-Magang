generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PEMBIMBING
  MAGANG
}

enum StatusAktivitas {
  DRAFT
  TERKIRIM
  DISETUJUI
  TELAT_MENGISI
}

model User {
  id              Int               @id @default(autoincrement())
  nama            String
  username        String            @unique
  password        String
  role            Role
  divisi          String?
  universitas     String?
  jurusan         String?
  angkatan        String?
  email           String?
  mentor          String?
  perusahaan      String?
  lokasi          String?
  tanggal_selesai DateTime?         @db.Date
  nickname        String?
  semester        String?
  no_telepon      String?
  id_magang       String?           @unique
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt
  aktivitas       AktivitasHarian[]
}

model AktivitasHarian {
  id                 Int               @id @default(autoincrement())
  user_id            Int
  user               User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tanggal            DateTime          @db.Date
  deskripsi_kegiatan String            @db.Text
  hasil_kegiatan     String            @db.Text
  waktu_mulai        String            @db.VarChar(5)
  waktu_selesai      String            @db.VarChar(5)
  kendala            String?           @db.Text
  status             StatusAktivitas   @default(DRAFT)
  created_at         DateTime          @default(now())
  updated_at         DateTime          @updatedAt
  lampiran           Lampiran[]

  @@map("aktivitas_harian")
}

model Lampiran {
  id           Int             @id @default(autoincrement())
  aktivitas_id Int
  aktivitas    AktivitasHarian @relation(fields: [aktivitas_id], references: [id], onDelete: Cascade)
  nama_file    String
  file_path    String
  created_at   DateTime        @default(now())

  @@map("lampiran")
}
